rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (Pillar 1/12)
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable global helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema Validation Helpers
    function isValidUser(data) {
      return data.uid is string && data.uid.size() <= 128 && data.uid == request.auth.uid
          && data.email is string && data.email.size() <= 128
          && data.displayName is string && data.displayName.size() <= 128;
    }

    function isValidBooking(data) {
      return data.id is string && data.id.size() <= 64
          && data.userId is string && data.userId.size() <= 128 && data.userId == request.auth.uid
          && data.patientName is string && data.patientName.size() <= 128
          && data.patientEmail is string && data.patientEmail.size() <= 128
          && data.patientPhone is string && data.patientPhone.size() <= 128
          && data.patientAge is string && data.patientAge.size() <= 8
          && data.patientGender is string && data.patientGender.size() <= 16
          && data.departmentId is string && data.departmentId.size() <= 64
          && data.departmentName is string && data.departmentName.size() <= 128
          && data.doctorId is string && data.doctorId.size() <= 64
          && data.doctorName is string && data.doctorName.size() <= 128
          && data.date is string && data.date.size() <= 32
          && data.timeSlot is string && data.timeSlot.size() <= 32
          && data.reason is string && data.reason.size() <= 2000
          && (data.status == 'Confirmed' || data.status == 'Cancelled')
          && (!('insuranceProvider' in data) || (data.insuranceProvider is string && data.insuranceProvider.size() <= 128));
    }

    // 1. Users Profile Collection
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId);
      
      allow create: if isSignedIn() 
          && (request.auth.uid == userId) 
          && isValidId(userId)
          && incoming().keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
          && incoming().keys().size() == 4
          && isValidUser(incoming())
          && incoming().createdAt is string
          && incoming().createdAt.size() <= 64;

      allow update: if isSignedIn()
          && (request.auth.uid == userId)
          && isValidId(userId)
          && incoming().keys().hasAll(['uid', 'email', 'displayName', 'createdAt'])
          && incoming().keys().size() == 4
          && isValidUser(incoming())
          && incoming().createdAt == existing().createdAt
          && incoming().email == existing().email;
    }

    // 2. Bookings Collection
    match /bookings/{bookingId} {
      allow get: if isSignedIn() && (existing().userId == request.auth.uid);
      
      // Pillar 8: Secure List Queries
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid);

      allow create: if isSignedIn()
          && isValidId(bookingId)
          && incoming().userId == request.auth.uid
          && incoming().status == 'Confirmed'
          && incoming().createdAt is string
          && incoming().createdAt.size() <= 64
          && isValidBooking(incoming())
          && incoming().keys().hasAll([
            'id', 'userId', 'patientName', 'patientEmail', 'patientPhone', 
            'patientAge', 'patientGender', 'departmentId', 'departmentName', 
            'doctorId', 'doctorName', 'date', 'timeSlot', 'reason', 'status', 'createdAt'
          ])
          && (
            incoming().keys().size() == 16 || 
            (incoming().keys().size() == 17 && 'insuranceProvider' in incoming())
          );

      // Pillar 4 & 6: Tiered and State locking updates
      allow update: if isSignedIn()
          && isValidId(bookingId)
          && existing().userId == request.auth.uid
          && existing().status == 'Confirmed'
          && incoming().status == 'Cancelled'
          && isValidBooking(incoming())
          && incoming().diff(existing()).affectedKeys().hasOnly(['status']);
    }

  }
}
